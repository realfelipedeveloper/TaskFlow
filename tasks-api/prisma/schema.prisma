generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int        @id @default(autoincrement())
  name          String     @db.VarChar(100)
  username      String     @unique(map: "username") @db.VarChar(50)
  email         String     @unique(map: "email") @db.VarChar(100)
  password_hash String     @db.VarChar(255)
  reset_token   String?    @db.VarChar(255)
  reset_expires DateTime?  @db.DateTime(0)
  created_at    DateTime?  @default(now()) @db.Timestamp(0)
  roles         UserRole[]
  taskAssignments TaskAssignee[]

  @@map("users")
}

model Task {
  id          Int            @id @default(autoincrement())
  title       String?        @db.VarChar(255)
  description String?        @db.LongText
  status      String?        @default("Aguardando aceitação") @db.VarChar(50)
  start_date  DateTime?      @db.Date
  due_date    DateTime?      @db.Date
  doubt       String?        @db.Text
  answer      String?        @db.Text
  created_at  DateTime?      @default(now()) @db.Timestamp(0)
  assignees   TaskAssignee[]
  branch      String?        @db.VarChar(100)
  project_id  Int?
  project     Project?       @relation(fields: [project_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  files       Json?

  @@map("tasks")
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String   @unique(map: "name") @db.VarChar(100)
  description String?  @db.Text
  created_at  DateTime? @default(now()) @db.Timestamp(0)
  tasks       Task[]

  @@map("projects")
}

model TaskAssignee {
  task_id Int
  user_id Int
  task    Task @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([task_id, user_id])
  @@index([user_id], map: "task_assignees_user_id_idx")
  @@map("task_assignees")
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique(map: "name") @db.VarChar(50)
  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model UserRole {
  user_id Int
  role_id Int
  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_roles_ibfk_1")
  role    Role @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_roles_ibfk_2")

  @@id([user_id, role_id])
  @@index([role_id], map: "role_id")
  @@map("user_roles")
}

model RolePermission {
  role_id    Int
  permission String @db.VarChar(50)
  role       Role   @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "role_permissions_ibfk_1")

  @@id([role_id, permission])
  @@map("role_permissions")
}
